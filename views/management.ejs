<h2>Welcome <%= account.firstname %></h2>

<% if (account.account_type === 'Employee' || account.account_type === 'Admin') { %>
  <h3>Inventory Management</h3>
  <p><a href="/inventory/manage">Manage Inventory</a></p>
<% } %>

<p><a href="/accounts/update/<%= account.account_id %>">Update Account Info</a></p>

<% if (errors && errors.length) { %>
  <ul>
    <% errors.forEach(err => { %>
      <li><%= err %></li>
    <% }) %>
  </ul>
<% } %>