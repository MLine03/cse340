<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Add Classification</title>
</head>
<body>
  <h1>Add Classification</h1>

  <% if (message) { %>
    <p style="color:red;"><%= message %></p>
  <% } %>

  <form action="/inventory/add-classification" method="POST">
    <input 
      type="text" 
      name="classificationName" 
      placeholder="Classification Name" 
      value="<%= previousInput.classificationName || '' %>" 
      required
    >
    <button type="submit">Add</button>
  </form>

  <a href="/">Home</a>
</body>
</html>