<!DOCTYPE html>
<html>
<head>
    <title><%= title %></title>
</head>
<body>
    <h1>Add Inventory Item</h1>
    <% if(message.length > 0){ %>
        <p><%= message %></p>
    <% } %>
    <form action="/inv/add-inventory" method="POST">
        <label for="inv_make">Make:</label>
        <input type="text" name="inv_make" id="inv_make" value="<%= sticky.inv_make || '' %>" required>
        <label for="inv_model">Model:</label>
        <input type="text" name="inv_model" id="inv_model" value="<%= sticky.inv_model || '' %>" required>
        <label for="inv_year">Year:</label>
        <input type="number" name="inv_year" id="inv_year" value="<%= sticky.inv_year || '' %>" required>
        <label for="inv_price">Price:</label>
        <input type="number" name="inv_price" id="inv_price" value="<%= sticky.inv_price || '' %>" required>
        <label for="inv_miles">Mileage:</label>
        <input type="number" name="inv_miles" id="inv_miles" value="<%= sticky.inv_miles || '' %>" required>
        <label for="inv_description">Description:</label>
        <textarea name="inv_description" id="inv_description"><%= sticky.inv_description || '' %></textarea>
        <label for="classification_id">Classification:</label>
        <%- classificationList %>
        <label for="inv_image">Image Path:</label>
        <input type="text" name="inv_image" id="inv_image" value="<%= sticky.inv_image || '' %>">
        <label for="inv_thumbnail">Thumbnail Path:</label>
        <input type="text" name="inv_thumbnail" id="inv_thumbnail" value="<%= sticky.inv_thumbnail || '' %>">
        <button type="submit">Add Inventory</button>
    </form>
</body>
</html>