<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
</head>
<body>
  <nav>
    <% if (account) { %>
      <span>Welcome, <%= account.firstname %>!</span>
      <a href="/accounts/update/<%= account.account_id %>">Update Account</a>
      <a href="/accounts/logout">Logout</a>
    <% } else { %>
      <a href="/login">Login</a>
    <% } %>
  </nav>

  <h1>Account Management</h1>

  <% if (message) { %>
    <p style="color:green;"><%= message %></p>
  <% } %>

  <% if (account.account_type === "Employee" || account.account_type === "Admin") { %>
    <h3>Inventory Management</h3>
    <p><a href="/inventory">Manage Inventory</a></p>
  <% } %>
</body>
</html>