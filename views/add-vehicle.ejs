<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add Vehicle</title>
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    /* Simple responsive layout */
    body { font-family: Arial, sans-serif; margin: 20px; }
    form { max-width: 600px; margin: auto; }
    label { display: block; margin-top: 15px; font-weight: bold; }
    input, select { width: 100%; padding: 8px; margin-top: 5px; }
    .error { color: red; margin-top: 5px; }
    button { margin-top: 20px; padding: 10px 20px; }
  </style>
</head>
<body>
  <h1>Add New Vehicle</h1>

  <% if (messages && messages.length > 0) { %>
    <ul>
      <% messages.forEach(msg => { %>
        <li class="error"><%= msg %></li>
      <% }) %>
    </ul>
  <% } %>

  <form action="/inventory/add-vehicle" method="POST" id="addVehicleForm">
    <label for="make">Make</label>
    <input type="text" id="make" name="make" value="<%= formData ? formData.make : '' %>" required>

    <label for="model">Model</label>
    <input type="text" id="model" name="model" value="<%= formData ? formData.model : '' %>" required>

    <label for="year">Year</label>
    <input type="number" id="year" name="year" min="1900" max="2100" value="<%= formData ? formData.year : '' %>" required>

    <label for="price">Price (USD)</label>
    <input type="number" id="price" name="price" step="0.01" value="<%= formData ? formData.price : '' %>" required>

    <label for="mileage">Mileage</label>
    <input type="number" id="mileage" name="mileage" value="<%= formData ? formData.mileage : '' %>" required>

    <label for="classification">Classification</label>
    <select name="classification" id="classification" required>
      <option value="">--Select Classification--</option>
      <% classifications.forEach(c => { %>
        <option value="<%= c.classification_id %>" <%= formData && formData.classification == c.classification_id ? 'selected' : '' %>><%= c.classification_name %></option>
      <% }) %>
    </select>

    <button type="submit">Add Vehicle</button>
  </form>

  <script>
    // Basic client-side validation
    const form = document.getElementById('addVehicleForm');
    form.addEventListener('submit', (e) => {
      const make = document.getElementById('make').value.trim();
      const model = document.getElementById('model').value.trim();
      const year = parseInt(document.getElementById('year').value);
      const price = parseFloat(document.getElementById('price').value);
      const mileage = parseFloat(document.getElementById('mileage').value);
      const classification = document.getElementById('classification').value;

      let errors = [];

      if (!make) errors.push("Make is required");
      if (!model) errors.push("Model is required");
      if (!year || year < 1900 || year > 2100) errors.push("Year must be between 1900 and 2100");
      if (!price || price <= 0) errors.push("Price must be greater than 0");
      if (!mileage || mileage < 0) errors.push("Mileage must be 0 or more");
      if (!classification) errors.push("Classification is required");

      if (errors.length > 0) {
        e.preventDefault();
        alert(errors.join("\\n"));
      }
    });
  </script>
</body>
</html>