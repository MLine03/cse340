<%- include("partials/head") %>
<%- include("partials/header") %>
<%- include("partials/nav") %>

<main>

  <h2>Welcome to CSE Motors</h2>

  <!-- HERO SECTION -->
  <section class="hero">

    <div class="hero-text">
      <h3>DMC Delorean</h3>

      <ul>
        <li>3 Cup holders</li>
        <li>Superman doors</li>
        <li>Fuzzy dice</li>
      </ul>

      <a href="#" class="btn">Own Today</a>
    </div>

    <div class="hero-image">
      <img src="/images/vehicles/delorean.jpg" alt="Delorean car">
    </div>

  </section>

  <!-- CONTENT SECTION -->
  <section class="content">

    <!-- UPGRADES -->
    <div class="upgrades">

      <h3>Delorean Upgrades</h3>

      <div class="upgrade-grid">

        <div class="upgrade">
          <img src="/images/upgrades/flux-cap.png" alt="Flux capacitor upgrade">
          <p>Flux Capacitor</p>
        </div>

        <div class="upgrade">
          <img src="/images/upgrades/flame.jpg" alt="Flame decals">
          <p>Flame Decals</p>
        </div>

        <div class="upgrade">
          <img src="/images/upgrades/bumper_sticker.jpg" alt="Bumper stickers">
          <p>Bumper Stickers</p>
        </div>

        <div class="upgrade">
          <img src="/images/upgrades/hub-cap.jpg" alt="Hub caps">
          <p>Hub Caps</p>
        </div>

      </div>

    </div>

    <!-- REVIEWS -->
    <div class="reviews">

      <h3>DMC Delorean Reviews</h3>

      <ul>
        <li>"So fast it's almost like traveling in time."</li>
        <li>"Coolest ride on the road."</li>
        <li>"I'm feeling Marty McFly!"</li>
        <li>"The most futuristic car I've driven."</li>
      </ul>

    </div>

  </section>

</main>

<%- include("partials/footer") %>