<!-- src/views/inventory.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Inventory listing page for CSE340 App">
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <header>
    <h1>CSE340 Inventory App</h1>
    <nav>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/inventory">Inventory</a></li>
        <li><a href="/account">Account</a></li>
      </ul>
    </nav>
  </header>

  <main>
    <h2><%= title %></h2>

    <% if (inventory.length === 0) { %>
      <p>No items in inventory.</p>
    <% } else { %>
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Classification</th>
            <th>Quantity</th>
          </tr>
        </thead>
        <tbody>
          <% inventory.forEach(item => { %>
            <tr>
              <td><%= item.inventory_id %></td>
              <td><%= item.name %></td>
              <td><%= item.classification_name %></td>
              <td><%= item.quantity %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>

  </main>

  <footer>
    <p>&copy; 2026 CSE340 Inventory App</p>
  </footer>
</body>
</html>